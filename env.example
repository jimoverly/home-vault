# ─── Home Vault Environment Configuration ───

# Server
PORT=3000

# Database (absolute path recommended for production)
DB_PATH=/var/lib/home-vault/home-vault.db

# Authentication
# CRITICAL: Generate a real secret before deploying!
#   openssl rand -hex 64
JWT_SECRET=CHANGE_ME
JWT_EXPIRY=8h
COOKIE_NAME=hv_session

# Password Hashing
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# CORS (development only — ignored in production)
CORS_ORIGIN=http://localhost:5173
